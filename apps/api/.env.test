# ──────────────────────────────────────────────────────────────────────────────
# NovaPay — Integration Test Environment
# ──────────────────────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.test.example .env.test
# 2. Create a Neon test branch: Neon Console → Branches → New Branch → "test"
# 3. Paste that branch's connection string as DATABASE_URL below
# 4. Push the schema once:
#      DATABASE_URL="<test-url>" npx prisma db push --schema=src/db/prisma/schema.prisma
# 5. Run:  npm run test:integration --workspace=apps/api
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=test
PORT=3002

# ▼ FILL THIS IN — your Neon test branch connection string
DATABASE_URL=postgresql://neondb_owner:npg_15UfGWImsewB@ep-young-dawn-apo1x5gd-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Auth — fixed test values (only used in tests, not secrets in CI)
JWT_SECRET=test-jwt-secret-must-be-at-least-32-characters-xx
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=test-refresh-token-secret-at-least-32-chars-x
REFRESH_TOKEN_EXPIRES_IN=30d

# Redis — the queue module is mocked so Redis is never actually connected
# but env validation requires a value
REDIS_URL=redis://localhost:6379

# Email — never actually sent; email queue is mocked in tests
RESEND_API_KEY=re_test_placeholder_key
EMAIL_FROM=test@novapay.test

# Blockchain — not used in tests
MORPH_RPC_URL=https://rpc-hoodi.morphl2.io
NOVAPAY_B2B_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Super admin
SUPER_ADMIN_JWT_SECRET=test-super-admin-jwt-secret-32-chars-minimum
SUPER_ADMIN_EMAIL=superadmin@test.novapay.io
ADMIN_SECRET=test-admin-secret16

# Frontend
FRONTEND_URL=http://localhost:5173
