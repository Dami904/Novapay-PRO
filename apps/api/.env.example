# ── SERVER ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── DATABASE (Neon Postgres) ─────────────────────────────────────────────────
# Get this from: neon.tech → your project → Connection string
DATABASE_URL=postgresql://neondb_owner:npg_15UfGWImsewB@ep-young-dawn-apo1x5gd-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# ── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars-different-from-above
REFRESH_TOKEN_EXPIRES_IN=30d

# ── REDIS (Upstash) ───────────────────────────────────────────────────────────
# Get this from: upstash.com → your Redis DB → REST API → REDIS_URL
REDIS_URL=redis-cli --tls -u redis://default:gQAAAAAAAZv4AAIgcDExZGIyOGRiYzljOWY0NTRhODdiZDM4NjJjNDQ3N2M3ZA@adjusted-turtle-105464.upstash.io:6379

# ── EMAIL (Gmail via Nodemailer) ─────────────────────────────────────────────
# Use your Gmail address + an App Password (myaccount.google.com → Security → App Passwords)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# ── FILE STORAGE (Cloudflare R2) ──────────────────────────────────────────────
# Get these from: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=novapay-uploads
# Public URL only needed if bucket is public — leave blank for private buckets
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── BLOCKCHAIN (Morph Hoodi L2) ───────────────────────────────────────────────
MORPH_RPC_URL=https://rpc-hoodi.morphl2.io
# Set this after deploying PayFlowB2B.sol — leave as zero address until then
NOVAPAY_B2B_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── SUPER ADMIN ───────────────────────────────────────────────────────────────
# Must be DIFFERENT from JWT_SECRET — used for platform-owner-only routes
SUPER_ADMIN_JWT_SECRET=your-super-admin-secret-different-from-main
SUPER_ADMIN_EMAIL=kolawolejoshua777@gmail.com

# ── FRONTEND URL (for CORS + email links) ─────────────────────────────────────
# Local dev: http://localhost:5173 | Production: https://nova-pay-kohl.vercel.app/
FRONTEND_URL= http://localhost:5173
