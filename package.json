{
  "name": "novapay",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "api:dev": "npm run dev --workspace=apps/api",
    "api:build": "npm run build --workspace=apps/api",
    "api:start": "npm run start --workspace=apps/api",
    "api:test": "npm run test --workspace=apps/api",
    "test:all": "npm run test && npm run api:test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "ethers": "^6.13.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^17.4.2",
    "hardhat": "^2.28.6",
    "jsdom": "^29.1.1",
    "vite": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
